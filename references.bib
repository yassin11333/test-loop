@article{deschutterVision3DPrinting2018,
  title = {Vision of {{3D}} Printing with Concrete — {{Technical}}, Economic and Environmental Potentials},
  author = {De Schutter, Geert and Lesage, Karel and Mechtcherine, Viktor and Nerella, Venkatesh Naidu and Habert, Guillaume and Agusti-Juan, Isolda},
