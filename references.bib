  author = {Chen, Yanjuan and Kuva, Jukka and Mohite, Ashish and Li, Zhongsen and Rahier, Hubert and Al-Neshawy, Fahim and Shu, Jiangpeng},
  date = {2023-03-22},
  journaltitle = {Materials},
